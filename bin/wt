#!/usr/bin/env zsh
# Create (or reuse) a git worktree for a branch and open a tmux window running
# the copilot (yolo) CLI in it, with side panes for install/watch.
#
# Usage: wt [-c|--cloud] [-r|--resume] <branch-name> [yolo prompt args...]
#   -c, --cloud    launch `yolo --cloud` (remote agent; skips the install pane)
#   -r, --resume   launch `yolo --resume` (interactive session picker) instead
#                  of starting a fresh session
#
# yolo is resolved in the interactive shell of the new tmux pane (it may be a
# zsh/work alias), so this script only ever sends it as a `tmux send-keys`
# string -- it never calls yolo directly.

emulate -L zsh
setopt no_nomatch

source "${0:A:h}/lib/wt-common.zsh"

local cloud_flag="" resume=""
while [[ "$1" == -* ]]; do
  case "$1" in
    -c|--cloud)  cloud_flag="--cloud" ;;
    -r|--resume) resume="1" ;;
    --) shift; break ;;
    *) echo "wt: unknown option '$1'" >&2; return 1 2>/dev/null || exit 1 ;;
  esac
  shift
done

if [[ -z "$1" ]]; then
  echo "Usage: wt [-c|--cloud] [-r|--resume] <branch-name> [yolo args...]"
  return 1 2>/dev/null || exit 1
fi

local branch_name="$1"
shift
local prompt_args="$*"

# Use the main worktree root (parent of the common git dir) so worktrees are
# always created under repo.worktrees/, even when run from another worktree.
local git_common_dir
git_common_dir=$(git rev-parse --path-format=absolute --git-common-dir) || exit 1
local repo_root="${git_common_dir%/.git}"
local wt_dir="${repo_root}.worktrees"
mkdir -p "$wt_dir"
local wt_path="${wt_dir}/${branch_name}"

# Determine branch name: skip devm33/ prefix if already present or existing.
local wt_branch
wt_branch=$(wt_branch_name "$branch_name")

# Reuse existing worktree if one exists for this branch, otherwise create one.
local existing_wt
existing_wt=$(wt_path_for_branch "$wt_branch")
if [[ -n "$existing_wt" ]]; then
  wt_path="$existing_wt"
elif [[ ! -d "$wt_path" ]]; then
  if git show-ref --verify --quiet "refs/heads/$wt_branch" || git show-ref --verify --quiet "refs/remotes/origin/$wt_branch"; then
    git worktree add "$wt_path" "$wt_branch" || exit 1
  else
    git worktree add -b "$wt_branch" "$wt_path" || exit 1
  fi
fi

# If a tmux window is already open at this worktree path, switch to it.
local existing_win
existing_win=$(tmux list-panes -a -F '#{pane_current_path} #{window_id}' 2>/dev/null | awk -v dir="$wt_path" '$1 == dir {print $2; exit}')
if [[ -n "$existing_win" ]]; then
  tmux select-window -t "$existing_win"
  exit 0
fi

# Create a new tmux window at the worktree path.
local win
win=$(tmux new-window -d -c "$wt_path" -P -F '#{window_id}')

# In the initial pane: run yolo with optional args.
local cloud_arg=""
[[ -n "$cloud_flag" ]] && cloud_arg=" ${cloud_flag}"
if [[ -n "$resume" ]]; then
  tmux send-keys -t "$win" "yolo${cloud_arg} --resume" Enter
elif [[ -n "$prompt_args" ]]; then
  local escaped_args="${prompt_args//\'/\'\\\'\'}"
  tmux send-keys -t "$win" "yolo${cloud_arg} --autopilot -i '${escaped_args}'" Enter
else
  tmux send-keys -t "$win" "yolo${cloud_arg}" Enter
fi

# Split vertically (left | right).
tmux split-window -h -t "$win" -c "$wt_path"

# Cloud mode runs the agent remotely, so skip the local install/build pane.
if [[ -n "$cloud_flag" ]]; then
  tmux select-pane -t "${win}.0"
  exit 0
fi

# Split the right pane horizontally (right-top / right-bottom).
tmux split-window -v -t "$win" -c "$wt_path"

# Target panes by index within the window:
#   0 = left           (yolo is already running here)
#   1 = right-top
#   2 = right-bottom

# Install deps (non-blocking, in pane 2) and optionally run watch.
local install_cmd=""
if [ -f "$wt_path/pnpm-lock.yaml" ]; then
  install_cmd="pnpm install"
elif [ -f "$wt_path/bun.lock" ]; then
  install_cmd="bun install"
elif [ -f "$wt_path/package.json" ]; then
  install_cmd="npm install"
fi
if [[ -n "$install_cmd" ]]; then
  local has_watch=false
  if (cd "$wt_path" && node -e "process.exit(JSON.parse(require('fs').readFileSync('package.json','utf8')).scripts?.watch?0:1)" 2>/dev/null) > /dev/null; then
    has_watch=true
  fi
  if $has_watch; then
    if [ -f "$wt_path/pnpm-lock.yaml" ]; then
      tmux send-keys -t "${win}.2" "$install_cmd && pnpm run watch" Enter
    elif [ -f "$wt_path/bun.lock" ]; then
      tmux send-keys -t "${win}.2" "$install_cmd && bun run watch" Enter
    else
      tmux send-keys -t "${win}.2" "$install_cmd && npm run watch" Enter
    fi
  else
    tmux send-keys -t "${win}.2" "$install_cmd" Enter
  fi
fi

# Focus back on the first pane.
tmux select-pane -t "${win}.0"
