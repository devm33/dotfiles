#!/usr/bin/env zsh
# Attach to the running tmux server, or start a new session if none is running.
# Deliberately minimal ("tmux attach || tmux") -- the worktree-window restore
# that used to live here now lives in `wtr`.

# During a codespace resume the environment (PATH, the tmux binary) may not be
# ready yet. Fail fast so csd's reconnect loop just retries, instead of letting
# the tmux calls below trip command_not_found_handler (which spams "command not
# found: tmux" and can even misfire yolo on the multi-word command).
command -v tmux >/dev/null 2>&1 || exit 1

# `tmux ls` succeeds only when the server is up AND has sessions, so a *transient*
# attach failure (e.g. the pty isn't ready yet on a flaky reconnect) exits
# non-zero and lets csd retry, instead of creating a duplicate session. -d
# detaches any stale/ghost client so this terminal gets the full size.
if tmux ls >/dev/null 2>&1; then
  exec tmux attach -d
fi

exec tmux new-session
