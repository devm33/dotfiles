#!/usr/bin/env zsh
# Attach to the running tmux server. If the server was killed (e.g. the codespace
# went offline), rebuild the windows from the last saved snapshot
# (bin/tmux-window-snapshot) in their original working dirs before attaching.
# Worktree windows relaunch `yolo --resume`; everything else is a plain shell.

# Attach to an existing server if there is one. -d detaches any other (possibly
# stale/ghost) client so this terminal gets the full size immediately.
tmux attach -d 2>/dev/null && exit

# Read the saved window dirs into memory *before* creating any tmux windows. The
# snapshot hooks fire as we rebuild, so reading afterwards would restore whatever
# transient state those hooks wrote instead of the list we want.
file="$HOME/.cache/wt/last-windows"
paths=()
if [[ -s "$file" ]]; then
  while IFS= read -r p; do
    [[ -n "$p" && -d "$p" ]] && paths+=("$p")
  done < "$file"
fi

# Nothing saved (or the dirs are gone): just start a normal session.
(( ${#paths} )) || exec tmux new-session

# Seed the session with the first dir (so there's no throwaway window to clean
# up) and add the rest detached (-d) so focus never jumps to each new window.
# -e SHELL_LOGGED_IN=true stops the codespace's /etc/zsh/zprofile from cd'ing
# every login shell back to the default workspace dir (which would clobber -c).
tmux new-session -d -e SHELL_LOGGED_IN=true -c "${paths[1]}"
# Set it server-wide too, so windows opened manually later (prefix-c) also skip
# the zprofile cd and stay in their own dir.
tmux set-environment -g SHELL_LOGGED_IN true
for p in "${(@)paths[2,-1]}"; do
  tmux new-window -d -e SHELL_LOGGED_IN=true -c "$p"
done

# Relaunch `yolo --resume` in every worktree window.
tmux list-windows -a -F '#{window_id} #{pane_current_path}' | while read -r win path; do
  [[ "$path" == *.worktrees/* ]] && tmux send-keys -t "$win" "yolo --resume" Enter
done

exec tmux attach -d
