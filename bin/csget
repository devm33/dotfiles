#!/usr/bin/env bash
# Copy a file OUT of a GitHub Codespace, reliably.
#
# `gh codespace cp` runs scp over a localhost port-forward into the codespace.
# In practice it often fails in both modes:
#   - default (SFTP)   -> "No such file or directory" even when the file exists
#   - legacy (`-- -O`) -> "protocol error: filename does not match request"
# The usual culprit is stray bytes on the remote login shell (an MOTD/banner or
# an rc file that prints something) corrupting scp's byte-exact control channel.
# `ssh -- 'cat FILE'` is immune: no control protocol to corrupt, and with no PTY
# there's no CRLF translation, so the stream is byte-for-byte (binary-safe).
#
# Usage:
#   csget <remote-path> [local-dest] [-c <codespace>] [--verify]
#
#   csget /workspaces/foo/demo.mp4                 # -> ./demo.mp4 (picks CS interactively)
#   csget /workspaces/foo/demo.mp4 ~/Downloads/    # -> ~/Downloads/demo.mp4
#   csget ~/some/file.txt out.txt -c my-codespace
#   csget /workspaces/foo/big.bin --verify         # compare sha256 after transfer
set -euo pipefail

cs=""
verify=0
args=()
while [ $# -gt 0 ]; do
  case "$1" in
    -c) cs="${2:-}"; shift 2 ;;
    --verify) verify=1; shift ;;
    -h|--help) sed -n '2,20p' "$0"; exit 0 ;;
    *) args+=("$1"); shift ;;
  esac
done

src="${args[0]:-}"
dest="${args[1]:-}"
if [ -z "$src" ]; then
  echo "usage: csget <remote-path> [local-dest] [-c <codespace>] [--verify]" >&2
  exit 1
fi

# Default dest = basename in cwd; if dest is an existing dir, append basename.
base="${src##*/}"
if [ -z "$dest" ]; then
  dest="$base"
elif [ -d "$dest" ]; then
  dest="${dest%/}/$base"
fi

# If no codespace was given, pick one ourselves instead of relying on
# `gh cs ssh`'s built-in picker, which needs a controlling TTY and fails with
# "error getting answers: no terminal" when stdin/stdout aren't a terminal.
if [ -z "$cs" ]; then
  list="$(gh cs list --json name,displayName,repository,gitStatus,state \
    --template '{{range .}}{{.name}}{{"\t"}}{{.displayName}}{{"\t"}}{{.repository}}{{"\t"}}{{.gitStatus.ref}}{{"\t"}}{{.state}}{{"\n"}}{{end}}')"
  if [ -z "$list" ]; then
    echo "csget: no codespaces found" >&2
    exit 1
  fi
  count=$(printf '%s\n' "$list" | grep -c . || true)
  if [ "$count" -eq 1 ]; then
    cs="$(printf '%s\n' "$list" | head -n1 | cut -f1)"
  elif [ -e /dev/tty ]; then
    if command -v fzf >/dev/null 2>&1; then
      choice="$(printf '%s\n' "$list" \
        | fzf --with-nth=2,3,4,5 --delimiter='\t' \
              --prompt='codespace> ' --height=40% --reverse)" || true
      cs="$(printf '%s' "$choice" | cut -f1)"
    else
      echo "Select a codespace:" >&2
      i=0
      while IFS=$'\t' read -r name disp repo branch state; do
        i=$((i+1))
        printf '  %2d) %s  (%s @ %s, %s)\n' "$i" "$disp" "$repo" "$branch" "$state" >&2
      done <<<"$list"
      printf 'number> ' >&2
      read -r n </dev/tty
      cs="$(printf '%s\n' "$list" | sed -n "${n}p" | cut -f1)"
    fi
  fi
  if [ -z "$cs" ]; then
    echo "csget: no codespace selected; pass one with -c <codespace>" >&2
    echo "available:" >&2
    printf '%s\n' "$list" | cut -f1 | sed 's/^/  /' >&2
    exit 1
  fi
fi

cflag=(-c "$cs")

# Single-quote the remote path so the remote shell treats it literally, and
# escape any embedded single quotes.
esc_src="${src//\'/\'\\\'\'}"

echo "↓ $src -> $dest" >&2

# Stream to a temp file, then move into place, so a failed transfer never leaves
# a truncated/empty file at $dest.
tmp="$(mktemp "${dest}.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

if ! gh cs ssh "${cflag[@]+"${cflag[@]}"}" -- "cat '$esc_src'" > "$tmp"; then
  echo "csget: transfer failed" >&2
  exit 1
fi

if [ "$verify" -eq 1 ]; then
  local_sum="$(shasum -a 256 < "$tmp" | awk '{print $1}')"
  remote_sum="$(gh cs ssh "${cflag[@]+"${cflag[@]}"}" -- "sha256sum '$esc_src'" | awk '{print $1}')"
  if [ "$local_sum" != "$remote_sum" ]; then
    echo "csget: checksum mismatch (local=$local_sum remote=$remote_sum)" >&2
    exit 1
  fi
  echo "✓ sha256 verified" >&2
fi

mv "$tmp" "$dest"
trap - EXIT

size=$(( $(wc -c < "$dest") ))
echo "✓ $dest ($size bytes)" >&2
