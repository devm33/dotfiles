#!/usr/bin/env zsh
# Fallback `yolo` for machines without a local build (e.g. codespaces). Prefer a
# locally built CLI in the codespace workspace when present, otherwise use the
# installed copilot binary. On work machines, dotfiles-work ships a real
# executable at ~/.local/bin/yolo (earlier on PATH than this ~/.bin/yolo) that
# execs the local build and so shadows this file.
#
# Lives in bin/ (not just as a zsh function) so it is resolvable from bash,
# tmux send-keys, and non-interactive `zsh -c` contexts (e.g. `csd` / `ta`).
emulate -L zsh
setopt local_options null_glob

local cli
for cli in /workspaces/*/dist-cli/index.js; do
  [[ -f "$cli" ]] && exec node "$cli" --yolo "$@"
done
exec copilot --yolo "$@"
