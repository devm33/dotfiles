#!/usr/bin/env zsh
# Print the Nerd Font glyph for a tmux tab: the current branch's PR status when
# the branch has a pull request, otherwise the icon for the running command.
#
# Meant for tmux window-status-format, taking the pane path and current command.
# The surrounding format supplies the spacing and resets fg afterwards so a PR
# status color does not bleed into the window name, e.g.:
#   "... #I #(tmux-window-icon #{pane_current_path} #{pane_current_command}) #[fg=cyan]#{b:...} ..."
#
# tmux re-expands every window's status line on each redraw (status-interval),
# so this stays cheap: it only reads a per-branch cache file and prints a glyph.
# Refreshing is done out of band by a single batched collector (--refresh-all)
# that fetches the PR status for *every* visible window in ONE GraphQL request,
# instead of one API call per window. Non-git / non-GitHub / no-PR tabs print
# nothing.
#
# Ported from caarlos0/dotfiles bin/tmux-window-icon (fish -> zsh).

emulate -L zsh
setopt no_nomatch

# This helper runs non-interactively and repeatedly cd's inside $(...) command
# substitutions to query per-repo state. Neutralize any chpwd hook inherited
# from the user's shell (e.g. an auto-ls / git-status printer on cd): otherwise
# that hook's output is captured by those substitutions and corrupts the result
# -- e.g. a directory listing leaking into a PR-check query and falsely marking
# a window's tab as failed (red).
chpwd_functions=()
unfunction chpwd 2>/dev/null

# Cache lifetime in seconds. PR status rarely changes minute-to-minute, and the
# cache is also invalidated on commit/push (the rev signature), so a long TTL
# avoids hammering the GitHub API from every window on every redraw. Override
# with TMUX_WINDOW_ICON_TTL.
ttl=${TMUX_WINDOW_ICON_TTL:-120}
cache_dir="$HOME/.cache/tmux-window-icon"
# Shared across all windows: when the collector last ran, and its run lock.
stampfile="$cache_dir/.all.stamp"
all_lock="$cache_dir/.all.lock"

# Filename-safe per-branch cache key from repo toplevel + branch. Must match
# between the fast path (reader) and the collector (writer).
state_key() { local k="$1#$2"; print -r -- "${k//[^A-Za-z0-9._-]/_}" }

# gh needs credentials for the PR-status lookups. On a normal machine gh reads a
# stored login from disk, but inside a Codespace it authenticates purely from
# $GITHUB_TOKEN -- and that variable is absent from the tmux server environment
# this script runs under, so every gh call would fail unauthenticated and all
# tabs would go blank. When no token is in the environment, fall back to the
# codespaces-managed env file, whose GITHUB_TOKEN the platform keeps refreshed.
# Override the path with TMUX_WINDOW_ICON_TOKEN_FILE.
ensure_gh_token() {
  # Already have a token in the environment: use it as-is.
  [[ -n "$GH_TOKEN" || -n "$GITHUB_TOKEN" ]] && return
  # Outside a Codespace (e.g. a local machine) gh authenticates from its own
  # stored login on disk, so there is nothing to inject -- leave it alone.
  [[ -n "$CODESPACES" ]] || return
  local envf=${TMUX_WINDOW_ICON_TOKEN_FILE:-/workspaces/.codespaces/shared/.env}
  [[ -r "$envf" ]] || return
  local t
  t=$(sed -n 's/^GITHUB_TOKEN=//p' "$envf" 2>/dev/null | head -1)
  [[ -n "$t" ]] && export GH_TOKEN="$t"
}

# PR-status glyphs + colors (Catppuccin Mocha).
# Nerd Font: f058 check-circle, f057 times-circle, f111 circle, e0a0 branch, f071 warning.
glyph_pass=$'\uf058'
glyph_fail=$'\uf057'
glyph_pending=$'\uf111'
glyph_merged=$'\ue0a0'
glyph_conflicts=$'\uf071'
color_pass='#a6e3a1'
color_fail='#f38ba8'
color_pending='#f9e2af'
color_merged='#cba6f7'
color_conflicts='#fab387'

# Return a styled glyph for one of the known states, or nothing. The case never
# echoes its input, so it can only ever produce a known PR-status glyph.
emit() {
  case "$1" in
    pass)      printf '#[fg=%s]%s' "$color_pass" "$glyph_pass" ;;
    fail)      printf '#[fg=%s]%s' "$color_fail" "$glyph_fail" ;;
    pending)   printf '#[fg=%s]%s' "$color_pending" "$glyph_pending" ;;
    merged)    printf '#[fg=%s]%s' "$color_merged" "$glyph_merged" ;;
    conflicts) printf '#[fg=%s]%s' "$color_conflicts" "$glyph_conflicts" ;;
  esac
}

# Seconds since the mtime of $1, or nothing if it does not exist.
age() {
  local m
  m=$(stat -f %m "$1" 2>/dev/null) || return
  [[ -n "$m" ]] && printf '%s' $(( $(date +%s) - m ))
}

# Nerd Font icon for a command name (merged from caarlos0 bin/icons), or nothing.
command_icon() {
  case "$1" in
    ack|fd|find|fzf|grep|rg) print -- '\uf422' ;;
    atop|htop|top) print -- '\uf200' ;;
    bash|fish|zsh|sh|ash) print -- '\ue795' ;;
    bat|cat) print -- '\uf1b0' ;;
    clx) print -- '\ue642' ;;
    copilot) print -- '\uf113' ;;
    cp|duplicate) print -- '\uf0c5' ;;
    diff) print -- '\uf4d2' ;;
    mv) print -- '\U000f0252' ;;
    curl|http|pint|lynx|wget|w3m) print -- '\uf484' ;;
    docker|docker-compose|podman) print -- '\uf308' ;;
    lf|ls|nnn|ranger|lsd) print -- '\uf413' ;;
    elixir|mix) print -- '\ue62d' ;;
    prowl) print -- '\U000f03d2' ;;
    gh|gh-dash) print -- '\ue708' ;;
    git|lazygit|tig) print -- '\ue725' ;;
    glow) print -- '\uf48a' ;;
    go|goreleaser) print -- '\ue627' ;;
    java|mvn) print -- '\ue256' ;;
    less|more) print -- '\uf036' ;;
    lua) print -- '\ue620' ;;
    man) print -- '\uf02d' ;;
    nano|pico) print -- '\uf15c' ;;
    node) print -- '\ued0d' ;;
    npm|pnpm) print -- '\ued0e' ;;
    nix*) print -- '\U000f1105' ;;
    vim|vi) print -- '\ue62b' ;;
    nvim) print -- '\uf36f' ;;
    python|pip) print -- '\ue73c' ;;
    rm) print -- '\uea81' ;;
    rsync) print -- '\uf46a' ;;
    rust|cargo|rustup) print -- '\ue7a8' ;;
    ruby|irb) print -- '\ue791' ;;
    scp|ssh) print -- '\U000f08c0' ;;
    sleep) print -- '\uf252' ;;
    sudo) print -- '\uf12a' ;;
    tail) print -- '\uf4ed' ;;
    task|make) print -- '\ue673' ;;
    tmux) print -- '\uebc8' ;;
    youtube-dl) print -- '\uf16a' ;;
    age|bw|gpg|op|pass|pinentry) print -- '\uf023' ;;
    ansible) print -- '\ue7a8' ;;
    bun) print -- '\ue76f' ;;
    composer) print -- '\ue783' ;;
    deno) print -- '\U000f07d3' ;;
    dig|nslookup|ping|traceroute|mtr|nc|netcat|nmap|tcpdump) print -- '\U000f06f3' ;;
    du|df|ncdu|dust) print -- '\uf7c9' ;;
    eslint) print -- '\ue655' ;;
    ffmpeg|mpv|yt-dlp) print -- '\uf03d' ;;
    helm) print -- '\u2388' ;;
    imagemagick|magick|convert) print -- '\uf03e' ;;
    jq|yq) print -- '\U000f0626' ;;
    mongo|mongosh) print -- '\ue7a4' ;;
    mysql|mariadb) print -- '\ue704' ;;
    openssl) print -- '\uf21b' ;;
    psql) print -- '\ue76e' ;;
    redis-cli) print -- '\ue76d' ;;
    screen) print -- '\uf489' ;;
    sqlite|sqlite3) print -- '\ue7c4' ;;
    swift) print -- '\ue755' ;;
    tar|zip|unzip|gzip|gunzip) print -- '\uf410' ;;
    terraform|tofu|tflint) print -- '\ue7b1' ;;
    time) print -- '\uf017' ;;
    tsc) print -- '\ue628' ;;
    watch) print -- '\uf254' ;;
    xcodebuild) print -- '\ue711' ;;
    yarn) print -- '\ue71e' ;;
    zig) print -- '\uf0e7' ;;
  esac
}

# --- batched collector: tmux-window-icon --refresh-all ---
# Fetches PR status for every branch currently shown in a tmux window using a
# single GraphQL request (one repository block per repo, one pullRequests alias
# per branch), then writes each branch's state file. The only follow-up API
# calls are for the rare PR whose checks are actually failing, to confirm the
# failure is on a *required* check before turning the tab red.
if [[ "$1" == --refresh-all ]]; then
  mkdir -p "$cache_dir" 2>/dev/null
  ensure_gh_token

  typeset -A seen repo_alias repo_query
  typeset -A a_branch a_dir a_rev a_top a_ra
  integer ri=0 bi=0

  # Discover every (repo, branch) visible in any pane, resolving everything
  # locally with git — no API calls just to enumerate.
  for dir in ${(u)${(f)"$(tmux list-panes -a -F '#{pane_current_path}' 2>/dev/null)"}}; do
    [[ -n "$dir" ]] || continue
    local -a info
    info=("${(@f)$(git -C "$dir" rev-parse HEAD --show-toplevel --abbrev-ref HEAD 2>/dev/null)}")
    (( ${#info} >= 3 )) || continue
    local head=${info[1]} top=${info[2]} branch=${info[3]}
    [[ "$branch" == HEAD ]] && continue   # detached: no branch to look up

    local url nwo
    url=$(git -C "$dir" remote get-url origin 2>/dev/null) || continue
    nwo=${url#*github.com[:/]}; nwo=${nwo%.git}
    [[ "$nwo" == */* ]] || continue       # not a github.com remote

    local key=$(state_key "$top" "$branch")
    [[ -n "${seen[$key]}" ]] && continue   # same worktree shown in several panes
    seen[$key]=1

    local up rev
    up=$(git -C "$dir" rev-parse --verify --quiet '@{upstream}' 2>/dev/null)
    rev="$head-$up"

    [[ -z "${repo_alias[$nwo]}" ]] && { repo_alias[$nwo]="r$ri"; (( ri++ )) }
    local ra=${repo_alias[$nwo]} ba="b$bi"; (( bi++ ))

    # Escape the branch name for a GraphQL string literal.
    local eb=${branch//\\/\\\\}; eb=${eb//\"/\\\"}
    repo_query[$nwo]+="$ba: pullRequests(headRefName:\"$eb\", first:1, orderBy:{field:CREATED_AT,direction:DESC}){ nodes{ state mergeable commits(last:1){ nodes{ commit{ statusCheckRollup{ state } } } } } } "
    a_branch[$ba]=$branch; a_dir[$ba]=$dir; a_rev[$ba]=$rev; a_top[$ba]=$top; a_ra[$ba]=$ra
  done

  if (( bi == 0 )); then
    : > "$stampfile"; rm -rf "$all_lock"; exit 0
  fi

  # Assemble and run the one batched query.
  local q="query{"
  local nwo ra
  for nwo ra in ${(kv)repo_alias}; do
    q+="$ra: repository(owner:\"${nwo%/*}\",name:\"${nwo#*/}\"){ ${repo_query[$nwo]} } "
  done
  q+="}"
  local result=$(gh api graphql -f query="$q" 2>/dev/null)

  local ba
  for ba in ${(k)a_branch}; do
    local state=none
    local node=$(print -r -- "$result" | jq -c ".data.${a_ra[$ba]}.${ba}.nodes[0] // empty" 2>/dev/null)
    if [[ -n "$node" ]]; then
      local s=$(print -r -- "$node" | jq -r '.state // empty')
      local m=$(print -r -- "$node" | jq -r '.mergeable // empty')
      local roll=$(print -r -- "$node" | jq -r '.commits.nodes[0].commit.statusCheckRollup.state // empty')
      case "$s" in
        MERGED) state=merged ;;
        OPEN|CLOSED)
          if [[ "$m" == CONFLICTING ]]; then
            state=conflicts
          else
            case "$roll" in
              SUCCESS)          state=pass ;;
              PENDING|EXPECTED) state=pending ;;
              FAILURE|ERROR)
                # The rollup aggregates required and non-required checks. Confirm
                # a *required* check is the one failing before going red; this is
                # the only place we spend an extra (rare) API call.
                local -a reqfails
                reqfails=("${(@f)$(cd "${a_dir[$ba]}" 2>/dev/null && gh pr checks --required --json bucket -q '.[].bucket | select(. == "fail" or . == "cancel")' 2>/dev/null)}")
                reqfails=(${reqfails:#})
                if (( ${#reqfails} > 0 )); then
                  state=fail
                else
                  local -a buckets
                  buckets=("${(@f)$(cd "${a_dir[$ba]}" 2>/dev/null && gh pr checks --json bucket -q '.[].bucket' 2>/dev/null)}")
                  buckets=(${buckets:#})
                  if (( ${buckets[(I)pending]} )); then state=pending; else state=pass; fi
                fi
                ;;
            esac
          fi
          ;;
      esac
    fi
    local sf="$cache_dir/$(state_key "${a_top[$ba]}" "${a_branch[$ba]}").state"
    local tmp="$sf.tmp.$$"
    printf '%s\n%s' "${a_rev[$ba]}" "$state" > "$tmp" && mv -f "$tmp" "$sf"
  done

  : > "$stampfile"
  rm -rf "$all_lock"
  exit 0
fi

# --- fast path (called by tmux with a pane path and the current command) ---
# Last arg is the command (for the icon fallback); the rest is the path.
cmd=""
dir=""
if (( $# >= 2 )); then
  cmd=${@[$#]}
  dir="${(j: :)@[1,-2]}"
else
  dir="$*"
fi

# PR status, only when the pane's directory is inside a git repo.
out=""
local -a info cached
if [[ -n "$dir" ]]; then
  info=("${(@f)$(git -C "$dir" rev-parse HEAD --show-toplevel --abbrev-ref HEAD 2>/dev/null)}")
fi
if (( ${#info} >= 3 )); then
  head=${info[1]}
  top=${info[2]}
  branch=${info[3]}

  # Revision signature: HEAD plus the push target, so commits, branch switches
  # and `git push` all invalidate the cache (the upstream ref moves on push).
  up=$(git -C "$dir" rev-parse --verify --quiet '@{upstream}' 2>/dev/null)
  rev="$head-$up"

  mkdir -p "$cache_dir" 2>/dev/null
  statefile="$cache_dir/$(state_key "$top" "$branch").state"

  # cache file is rev then state
  [[ -f "$statefile" ]] && cached=("${(@f)$(cat "$statefile")}")
  (( ${#cached} >= 2 )) && out=$(emit "${cached[2]}")

  # Decide whether the shared collector should run: when this branch has no
  # cached state, when its revision changed (commit/push), or when the last
  # batched refresh is older than the TTL.
  need_refresh=0
  if (( ${#cached} < 2 )) || [[ "${cached[1]}" != "$rev" ]]; then
    need_refresh=1
  else
    st=$(age "$stampfile")
    [[ -z "$st" ]] || (( st >= ttl )) && need_refresh=1
  fi

  if (( need_refresh )); then
    # One collector for all windows: only the process that wins the shared lock
    # spawns it; a stale lock (crashed run) is reclaimed after 120s.
    locked=0
    if mkdir "$all_lock" 2>/dev/null; then
      locked=1
    else
      lt=$(age "$all_lock")
      if [[ -n "$lt" ]] && (( lt > 120 )); then
        rm -rf "$all_lock" && mkdir "$all_lock" 2>/dev/null && locked=1
      fi
    fi
    if (( locked )); then
      # Redirect ALL std streams: tmux runs #() over a socketpair, so an
      # inherited stdin would keep the socket open and tmux would show
      # "<'...' not ready>" until the slow gh call finishes. Detach fully (&!).
      "$0" --refresh-all </dev/null >/dev/null 2>&1 &!
    fi
  fi
fi

# Show the PR status glyph if we have one; otherwise the icon for the command,
# falling back to a generic terminal glyph (Nerd Font f489) when nothing matches.
[[ -z "$out" && -n "$cmd" ]] && out=$(command_icon "$cmd")
[[ -z "$out" ]] && out=$'\uf489'
printf '%s' "$out"
