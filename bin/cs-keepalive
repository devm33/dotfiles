#!/usr/bin/env bash
# Keep GitHub Codespaces alive by touching each running one periodically. Two
# distinct clocks need feeding, and they respond to different actions:
#
#   1. idle timeout (stops a RUNNING codespace; 4h max) -- reset ONLY by real
#      connection activity. An `ssh -- true` counts; a POST /start does NOT
#      (verified experimentally: a 5-min-idle codespace touched via start every
#      2 min still stopped at ~5 min). So we SSH-ping to hold it open.
#   2. last_used_at / retention (deletes a STOPPED codespace after the
#      retention window) -- refreshed by POST /start on a running codespace,
#      which is a no-op that does NOT restart it. We also POST /start so
#      last_used_at stays current.
#
# Run from launchd (Mac, while awake) and/or a scheduled GitHub Action
# (always-on) -- see config/launchd/ and .github/workflows/cs-keepalive.yml.
#
# Only touches codespaces that are already running (state "Available"); it
# never starts a stopped one -- POST /start WOULD resurrect a codespace you
# deliberately stopped (restarting it, killing its sessions, burning quota),
# so the "Available" guard is required.
#
# Usage:
#   cs-keepalive                 # touch every running codespace (default)
#   cs-keepalive NAME [NAME...]   # touch only the named codespace(s)
set -eo pipefail

log() { printf '%s cs-keepalive: %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$*"; }

command -v gh >/dev/null 2>&1 || { log "gh not found on PATH"; exit 127; }

targets=("$@")
if [ "${#targets[@]}" -eq 0 ]; then
  # Default: whatever is currently running.
  while IFS= read -r n; do
    [ -n "$n" ] && targets+=("$n")
  done < <(gh codespace list --json name,state \
             --jq '.[] | select(.state=="Available") | .name')
fi

if [ "${#targets[@]}" -eq 0 ]; then
  log "no running codespaces to touch"
  exit 0
fi

rc=0
for cs in "${targets[@]}"; do
  state="$(gh codespace view -c "$cs" --json state --jq .state 2>/dev/null || echo unknown)"
  if [ "$state" != "Available" ]; then
    log "skip $cs (state=$state) -- not resurrecting a stopped codespace"
    continue
  fi
  # SSH activity resets the idle timer (holds the codespace open).
  if gh codespace ssh -c "$cs" -- true 2>/dev/null; then
    ping_ok=1
  else
    ping_ok=0
    rc=1
  fi
  # POST /start on the running codespace refreshes last_used_at (retention)
  # without restarting it; it does NOT reset the idle timer.
  if gh api --silent -X POST "/user/codespaces/$cs/start" 2>/dev/null; then
    touch_ok=1
  else
    touch_ok=0
    rc=1
  fi
  if [ "$ping_ok" = 1 ] && [ "$touch_ok" = 1 ]; then
    log "kept $cs alive (idle timer reset, last_used_at refreshed)"
  elif [ "$ping_ok" = 1 ]; then
    log "pinged $cs (idle reset) but last_used_at refresh FAILED"
  elif [ "$touch_ok" = 1 ]; then
    log "refreshed last_used_at for $cs but SSH idle-reset FAILED"
  else
    log "keepalive FAILED for $cs"
  fi
done
exit "$rc"
