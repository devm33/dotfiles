#!/usr/bin/env bash
# Copilot CLI hook to show activity indicator in tmux window status.
# Usage: tmux-copilot-hook start | stop
# Called from ~/.copilot/hooks/tmux-status.json hooks.
#
# Must use explicit -t target because hooks are spawned with piped stdio
# (no TTY), so tmux cannot identify the correct window automatically.

[ -n "${TMUX:-}" ] || exit 0
[ -n "${TMUX_PANE:-}" ] || exit 0

case "${1:-}" in
    start) tmux set-option -w -t "$TMUX_PANE" @copilot_busy 1 ;;
    stop)  tmux set-option -wqu -t "$TMUX_PANE" @copilot_busy 2>/dev/null || true ;;
esac

# Force an immediate status-line repaint. The window status shows a progress
# spinner from the pane's OSC 9;4 state (#{pane_pb_state}), but tmux only
# repaints a *background* window's status on the next status-interval tick or
# when that window is selected -- so the spinner would otherwise lag or vanish
# until you switch to the window. Refreshing here makes it appear/clear the
# instant Copilot starts or stops working.
tmux refresh-client -S 2>/dev/null || true
