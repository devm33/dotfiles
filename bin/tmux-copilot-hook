#!/usr/bin/env bash
# Copilot CLI hook to show a busy spinner in the tmux window status.
# Usage: tmux-copilot-hook start | stop
# Called from ~/.copilot/hooks/tmux-status.json hooks.
#
# Must use an explicit -t target because hooks are spawned with piped stdio
# (no TTY), so tmux cannot identify the correct pane/window automatically.
#
# Why a per-window *set* of pane ids (not the pane's OSC 9;4 progress state):
#   - The status line's #{pane_pb_state} only reflects a window's *active*
#     pane, so a Copilot working in a background pane of a window would show no
#     spinner (and selecting the window would flip it). A window option is
#     evaluated per-window regardless of which pane is active.
#   - A window can host several Copilot panes, so a single flag/counter is
#     ambiguous. We store the set of busy pane ids and treat the window as busy
#     while the set is non-empty. Dead pane ids are pruned on every update so a
#     pane that exits mid-turn (without firing 'stop') can't leak a stuck
#     spinner.

# Optional debug logging: set COPILOT_HOOK_LOG=/path to trace hook invocations.
[ -n "${COPILOT_HOOK_LOG:-}" ] && \
    printf '%s pane=%s arg=%s tmux=%s\n' "$(date +%H:%M:%S)" "${TMUX_PANE:-}" "${1:-}" "${TMUX:+set}" \
    >> "$COPILOT_HOOK_LOG" 2>/dev/null

[ -n "${TMUX:-}" ] || exit 0
[ -n "${TMUX_PANE:-}" ] || exit 0

win=$(tmux display-message -p -t "$TMUX_PANE" '#{window_id}' 2>/dev/null) || exit 0
[ -n "$win" ] || exit 0

# Serialize concurrent hook invocations for the SAME window. Several Copilot
# panes in one window can fire start/stop at nearly the same instant; without a
# lock the read-modify-write on @copilot_busy below races and one process can
# clobber another (dropping a busy pane's id -> its spinner briefly vanishes).
# macOS has no flock(1), so use an atomic mkdir lock (portable, no deps).
lockdir="${TMPDIR:-/tmp}/copilot-busy-${win//[^A-Za-z0-9]/_}.lock"
have_lock=""
i=0
while [ $i -lt 50 ]; do
    if mkdir "$lockdir" 2>/dev/null; then
        have_lock=1
        break
    fi
    # Break a stale lock left by a hook that died mid-update (critical section is
    # a few tmux calls, so a lock older than ~2s is certainly abandoned).
    lock_mtime=$(stat -f %m "$lockdir" 2>/dev/null || echo 0)
    if [ "$lock_mtime" -ne 0 ] && [ $(( $(date +%s) - lock_mtime )) -ge 2 ]; then
        rmdir "$lockdir" 2>/dev/null || true
    fi
    sleep 0.05
    i=$((i + 1))
done
# If we still couldn't get the lock, proceed best-effort rather than deadlock.
[ -n "$have_lock" ] && trap 'rmdir "$lockdir" 2>/dev/null || true' EXIT

current=$(tmux show-options -wqv -t "$win" @copilot_busy 2>/dev/null)
live=" $(tmux list-panes -t "$win" -F '#{pane_id}' 2>/dev/null | tr '\n' ' ') "

# Rebuild the set: keep only still-alive panes, always dropping this pane (it is
# re-added below only for 'start'). This both removes it on 'stop' and prunes
# any leaked ids for panes that no longer exist.
new=""
for p in $current; do
    [ "$p" = "$TMUX_PANE" ] && continue
    case "$live" in *" $p "*) new="$new $p" ;; esac
done
[ "${1:-}" = start ] && new="$new $TMUX_PANE"
new="${new# }"

if [ -n "$new" ]; then
    tmux set-option -w -t "$win" @copilot_busy "$new"
else
    tmux set-option -wqu -t "$win" @copilot_busy 2>/dev/null || true
fi

# Repaint the status now so the spinner appears/clears immediately instead of
# waiting for the next status-interval tick or a window selection.
tmux refresh-client -S 2>/dev/null || true
