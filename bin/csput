#!/usr/bin/env bash
# Copy a file INTO a GitHub Codespace, reliably.
#
# Companion to `csget`. Streams the local file over `ssh -- 'cat > FILE'`,
# sidestepping the same `gh codespace cp` scp failures (see csget for the why).
# No PTY is allocated, so the byte stream is unmodified (binary-safe).
#
# Usage:
#   csput <local-path> <remote-path> [-c <codespace>] [--verify]
#
#   csput ./patch.diff /workspaces/proj/patch.diff
#   csput ./big.bin ~/big.bin -c my-codespace --verify
set -euo pipefail

cs=""
verify=0
args=()
while [ $# -gt 0 ]; do
  case "$1" in
    -c) cs="${2:-}"; shift 2 ;;
    --verify) verify=1; shift ;;
    -h|--help) sed -n '2,12p' "$0"; exit 0 ;;
    *) args+=("$1"); shift ;;
  esac
done

src="${args[0]:-}"
dest="${args[1]:-}"
if [ -z "$src" ] || [ -z "$dest" ]; then
  echo "usage: csput <local-path> <remote-path> [-c <codespace>] [--verify]" >&2
  exit 1
fi
if [ ! -f "$src" ]; then
  echo "csput: no such local file: $src" >&2
  exit 1
fi

# If no codespace was given, pick one ourselves instead of relying on
# `gh cs ssh`'s built-in picker, which needs a controlling TTY and fails with
# "error getting answers: no terminal" when stdin/stdout aren't a terminal.
# (For csput stdin is the payload file, so gh's picker can never work anyway.)
if [ -z "$cs" ]; then
  list="$(gh cs list --json name,displayName,repository,gitStatus,state \
    --template '{{range .}}{{.name}}{{"\t"}}{{.displayName}}{{"\t"}}{{.repository}}{{"\t"}}{{.gitStatus.ref}}{{"\t"}}{{.state}}{{"\n"}}{{end}}')"
  if [ -z "$list" ]; then
    echo "csput: no codespaces found" >&2
    exit 1
  fi
  count=$(printf '%s\n' "$list" | grep -c . || true)
  if [ "$count" -eq 1 ]; then
    cs="$(printf '%s\n' "$list" | head -n1 | cut -f1)"
  elif [ -e /dev/tty ]; then
    if command -v fzf >/dev/null 2>&1; then
      choice="$(printf '%s\n' "$list" \
        | fzf --with-nth=2,3,4,5 --delimiter='\t' \
              --prompt='codespace> ' --height=40% --reverse </dev/tty >/dev/tty)" || true
      cs="$(printf '%s' "$choice" | cut -f1)"
    else
      echo "Select a codespace:" >&2
      i=0
      while IFS=$'\t' read -r name disp repo branch state; do
        i=$((i+1))
        printf '  %2d) %s  (%s @ %s, %s)\n' "$i" "$disp" "$repo" "$branch" "$state" >&2
      done <<<"$list"
      printf 'number> ' >&2
      read -r n </dev/tty
      cs="$(printf '%s\n' "$list" | sed -n "${n}p" | cut -f1)"
    fi
  fi
  if [ -z "$cs" ]; then
    echo "csput: no codespace selected; pass one with -c <codespace>" >&2
    echo "available:" >&2
    printf '%s\n' "$list" | cut -f1 | sed 's/^/  /' >&2
    exit 1
  fi
fi

cflag=(-c "$cs")

esc_dest="${dest//\'/\'\\\'\'}"

echo "↑ $src -> $dest" >&2

if ! gh cs ssh "${cflag[@]+"${cflag[@]}"}" -- "cat > '$esc_dest'" < "$src"; then
  echo "csput: transfer failed" >&2
  exit 1
fi

if [ "$verify" -eq 1 ]; then
  local_sum="$(shasum -a 256 < "$src" | awk '{print $1}')"
  remote_sum="$(gh cs ssh "${cflag[@]+"${cflag[@]}"}" -- "sha256sum '$esc_dest'" | awk '{print $1}')"
  if [ "$local_sum" != "$remote_sum" ]; then
    echo "csput: checksum mismatch (local=$local_sum remote=$remote_sum)" >&2
    exit 1
  fi
  echo "✓ sha256 verified" >&2
fi

echo "✓ uploaded" >&2
