# zsh completions for the worktree / code-review commands.
# Sourced from .zshrc after compinit (compdef must exist). The commands
# themselves live either in bin/ scripts (wt, wtrm, cr) or as functions in
# zsh/aliases (wtc, crc, wtp, wtD); compdef attaches to the command name
# regardless of which.

# Complete on local + remote branch names (deduped, HEAD/remotes prefix stripped).
_wt_branches() { compadd $(git branch -a --no-column --no-color | sed 's/^[+* ]*//' | grep -v 'HEAD' | sed 's|remotes/origin/||' | sort -u) }
compdef _wt_branches wt
compdef _wt_branches wtc
compdef _wt_branches cr
compdef _wt_branches crc
compdef _wt_branches wtp

# Complete on the branch names that currently have a worktree.
_wt_worktrees() { compadd $(git worktree list --porcelain | awk -F/ '/^branch refs\/heads\//{print $NF}') }
compdef _wt_worktrees wtD
compdef _wt_worktrees wtrm

# Augment pnpm's completion so that at the command position it also offers
# `pnpm run` script names -- since `pnpm build` (and `p build`, alias p='pnpm')
# is shorthand for `pnpm run build`. zsh auto-expands the `p` alias to `pnpm`
# for completion, so hooking `pnpm` covers `p` too.
#
# The two sources are merged with `_alternative` (the native zsh helper for
# offering several completion sources in one context). pnpm only exposes script
# names through its context-sensitive completion server, so the script source
# asks it as though the line were `pnpm run <word>`.
_pnpm_scripts() {
  local word=$words[CURRENT] line reply si=$IFS
  line="pnpm run $word"
  IFS=$'\n' reply=($(COMP_CWORD=2 COMP_LINE="$line" COMP_POINT=$#line \
    SHELL=zsh pnpm completion-server -- pnpm run "$word"))
  IFS=$si
  (( $#reply )) && _describe -t scripts 'script' reply
}
_pnpm_with_scripts() {
  if (( CURRENT == 2 )) && [[ -n $words[CURRENT] ]]; then
    _alternative 'commands:command:_pnpm' 'scripts:script:_pnpm_scripts'
  else
    _pnpm "$@"
  fi
}
compdef _pnpm_with_scripts pnpm
