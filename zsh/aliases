wt() {
  if [[ -z "$1" ]]; then
    echo "Usage: wt <branch-name> [yolo args...]"
    return 1
  fi

  local branch_name="$1"
  shift
  local prompt_args="$*"
  local wt_path="$HOME/code/wt/$branch_name"

  # Fetch latest branches
  git pull || return 1

  # Determine branch name: skip devm33/ prefix if already present or if it's an existing branch
  local wt_branch
  if [[ "$branch_name" == devm33/* ]] || git show-ref --verify --quiet "refs/heads/$branch_name" || git show-ref --verify --quiet "refs/remotes/origin/$branch_name"; then
    wt_branch="$branch_name"
  else
    wt_branch="devm33/$branch_name"
  fi

  # Reuse existing worktree if one exists for this branch, otherwise create one
  local existing_wt
  existing_wt=$(git worktree list --porcelain | awk -v branch="refs/heads/$wt_branch" '/^worktree /{wt=$0} $0 == "branch " branch {sub(/^worktree /, "", wt); print wt}')
  if [[ -n "$existing_wt" ]]; then
    wt_path="$existing_wt"
  elif [[ ! -d "$wt_path" ]]; then
    if git show-ref --verify --quiet "refs/heads/$wt_branch" || git show-ref --verify --quiet "refs/remotes/origin/$wt_branch"; then
      git worktree add "$wt_path" "$wt_branch" || return 1
    else
      git worktree add -b "$wt_branch" "$wt_path" || return 1
    fi
  fi

  # Install dependencies in the new worktree
  if [ -f "$wt_path/package.json" ]; then
    (cd "$wt_path" && npm install)
  fi

  # Create a new tmux window at the worktree path
  local win
  win=$(tmux new-window -d -c "$wt_path" -P -F '#{window_id}')

  # In the initial pane: run yolo with optional args
  if [[ -n "$prompt_args" ]]; then
    local escaped_args="${prompt_args//\'/\'\\\'\'}"
    tmux send-keys -t "$win" "yolo -i '${escaped_args}'" Enter
  else
    tmux send-keys -t "$win" "yolo" Enter
  fi

  # Split vertically (left | right)
  tmux split-window -h -t "$win" -c "$wt_path"

  # Split the right pane horizontally (right-top / right-bottom)
  tmux split-window -v -t "$win" -c "$wt_path"

  # Target panes by index within the window:
  #   0 = left           (yolo is already running here)
  #   1 = right-top
  #   2 = right-bottom

  tmux send-keys -t "${win}.2" "npm run watch" Enter

  # Focus back on the first pane
  tmux select-pane -t "${win}.0"
}
# Delete branch and its associated worktree (if any)
gbDW() {
  for b in "$@"; do
    wt=$(git worktree list --porcelain | awk -v branch="refs/heads/$b" '/^worktree /{wt=$0} $0 == "branch " branch {sub(/^worktree /, "", wt); print wt}')
    if [ -n "$wt" ]; then
      echo "Removing worktree: $wt (branch: $b)"
      git worktree remove --force "$wt"
    fi
    git branch -D "$b"
  done
}
# Remove worktrees for gone branches, then delete the branches
gwgD() {
  for b in $(LANG=C git branch --no-color -vv | grep ": gone\]" | sed 's/^[+* ]*//' | awk '{print $1}'); do
    wt=$(git worktree list --porcelain | awk -v branch="refs/heads/$b" '/^worktree /{wt=$0} $0 == "branch " branch {sub(/^worktree /, "", wt); print wt}')
    if [ -n "$wt" ]; then
      echo "Removing worktree: $wt (branch: $b)"
      # Close any tmux window with panes in this worktree
      if [ -n "$TMUX" ]; then
        local win_id
        win_id=$(tmux list-panes -s -F '#{window_id} #{pane_current_path}' | awk -v wt="$wt" '$2 == wt || index($2, wt"/") == 1 {print $1; exit}')
        if [ -n "$win_id" ]; then
          echo "Closing tmux window: $win_id"
          tmux kill-window -t "$win_id"
        fi
      fi
      git worktree remove --force "$wt"
      rm -rf "$wt"
    fi
    git branch -D "$b"
  done
}
alias wgwD='gwgD'
# Delete a single worktree by name and force delete its branch
wtD() {
  if [[ -z "$1" ]]; then
    echo "Usage: wtD <branch-name>"
    return 1
  fi

  local wt_path="$HOME/code/wt/$1"

  # Determine branch name using the same logic as wt
  local wt_branch
  if [[ "$1" == devm33/* ]] || git show-ref --verify --quiet "refs/heads/$1" || git show-ref --verify --quiet "refs/remotes/origin/$1"; then
    wt_branch="$1"
  else
    wt_branch="devm33/$1"
  fi

  # Remove the worktree if it exists
  local wt
  wt=$(git worktree list --porcelain | awk -v branch="refs/heads/$wt_branch" '/^worktree /{wt=$0} $0 == "branch " branch {sub(/^worktree /, "", wt); print wt}')
  if [ -n "$wt" ]; then
    echo "Removing worktree: $wt (branch: $wt_branch)"
    git worktree remove --force "$wt"
  fi

  git branch -D "$wt_branch"
}
_wt_branches() { compadd $(git branch -a --no-column --no-color | sed 's/^[* ]*//' | sed 's|remotes/origin/||' | sort -u) }
