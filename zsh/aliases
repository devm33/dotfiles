# Create a codespace for the current repo on the given branch (defaults to
# main) and print its name to stdout. Progress goes to stderr so the name can
# be captured with `name=$(cs [branch])`. When run interactively it also ssh's
# into the new codespace.
cs() {
  local branch="${1:-main}"
  local repo
  repo=$(gh repo view --json nameWithOwner -q .nameWithOwner) || return 1

  echo "Creating codespace for $repo on branch $branch..." >&2
  # Pick a machine type so create doesn't try to prompt (it can't, since its
  # output is captured -> "no terminal"). Honor $CS_MACHINE if set, otherwise
  # default to the largest available (most cpus, then most storage).
  local machine="${CS_MACHINE:-}"
  if [[ -z "$machine" ]]; then
    machine=$(gh api "/repos/$repo/codespaces/machines" \
      --jq '.machines | sort_by(.cpus, .storage_in_bytes) | last | .name' 2>/dev/null)
  fi
  local -a machine_flag
  [[ -n "$machine" ]] && machine_flag=(-m "$machine")
  local name
  name=$(gh codespace create -R "$repo" -b "$branch" --default-permissions "${machine_flag[@]}") || return 1
  echo "$name"

  # Codespaces apply dotfiles (which install tmux, zsh, etc.) asynchronously
  # after the container is ready, so connecting immediately races that setup.
  # Wait for install.sh to log completion before returning / connecting.
  echo "Waiting for dotfiles install to finish..." >&2
  gh codespace ssh -c "$name" -- 'for i in $(seq 1 150); do grep -q "Dotfiles install complete" /workspaces/.codespaces/.persistedshare/creation.log 2>/dev/null && exit 0; sleep 2; done' 2>/dev/null

  # When run interactively (stdout is a terminal) connect to the codespace. When
  # the output is captured (e.g. by ccr) just return the name.
  if [[ -t 1 ]]; then
    echo "Connecting to $name..." >&2
    gh codespace ssh -c "$name"
  fi
}
