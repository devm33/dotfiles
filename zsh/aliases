# Fallback `yolo` for machines without zsh/work (e.g. codespaces). Prefer a
# locally built CLI in the codespace workspace when present, otherwise use the
# installed copilot binary. zsh/work overrides this with its own yolo when
# available.
yolo() {
  local cli
  for cli in /workspaces/*/dist-cli/index.js(N); do
    [[ -f "$cli" ]] && { node "$cli" --yolo "$@"; return; }
  done
  copilot --yolo "$@"
}
# Delete branch and its associated worktree (if any)
gbDW() {
  for b in "$@"; do
    wt=$(git worktree list --porcelain | awk -v branch="refs/heads/$b" '/^worktree /{wt=$0} $0 == "branch " branch {sub(/^worktree /, "", wt); print wt}')
    if [ -n "$wt" ]; then
      echo "Removing worktree: $wt (branch: $b)"
      git worktree remove --force "$wt"
    fi
    git branch -D "$b"
  done
}
# Remove worktrees for gone branches, then delete the branches
gwgD() {
  for b in $(LANG=C git branch --no-color -vv | grep ": gone\]" | sed 's/^[+* ]*//' | awk '{print $1}'); do
    wt=$(git worktree list --porcelain | awk -v branch="refs/heads/$b" '/^worktree /{wt=$0} $0 == "branch " branch {sub(/^worktree /, "", wt); print wt}')
    if [ -n "$wt" ]; then
      echo "Removing worktree: $wt (branch: $b)"
      # Close any tmux window with panes in this worktree
      if [ -n "$TMUX" ]; then
        local win_id
        win_id=$(tmux list-panes -s -F '#{window_id} #{pane_current_path}' | awk -v wt="$wt" '$2 == wt || index($2, wt"/") == 1 {print $1; exit}')
        if [ -n "$win_id" ]; then
          echo "Closing tmux window: $win_id"
          tmux kill-window -t "$win_id"
        fi
      fi
      git worktree remove --force "$wt"
      rm -rf "$wt"
    fi
    git branch -D "$b"
  done
}
alias wgwD='gwgD'
# Delete a single worktree by name and force delete its branch
wtD() {
  if [[ -z "$1" ]]; then
    echo "Usage: wtD <branch-name>"
    return 1
  fi

  local repo_root
  repo_root=$(git rev-parse --show-toplevel) || return 1

  # Determine branch name using the same logic as wt
  local wt_branch
  if [[ "$1" == devm33/* ]] || git show-ref --verify --quiet "refs/heads/$1" || git show-ref --verify --quiet "refs/remotes/origin/$1"; then
    wt_branch="$1"
  else
    wt_branch="devm33/$1"
  fi

  # Remove the worktree if it exists
  local wt
  wt=$(git worktree list --porcelain | awk -v branch="refs/heads/$wt_branch" '/^worktree /{wt=$0} $0 == "branch " branch {sub(/^worktree /, "", wt); print wt}')
  if [ -n "$wt" ]; then
    echo "Removing worktree: $wt (branch: $wt_branch)"
    git worktree remove --force "$wt"
  fi

  git branch -D "$wt_branch"
}
# Reopen the tmux windows from the last saved snapshot (bin/tmux-window-snapshot,
# kept current by tmux hooks). Worktree windows (under *.worktrees/*) relaunch
# `yolo --resume` so you can pick the session that was running there; other
# windows reopen as a plain shell. Windows already open are skipped.
wtr() {
  if [[ -z "$TMUX" ]]; then
    echo "wtr: must be run inside tmux"
    return 1
  fi
  local file="$HOME/.cache/wt/last-windows"
  if [[ ! -s "$file" ]]; then
    echo "wtr: no saved windows ($file)"
    return 1
  fi

  # Paths already open, to avoid creating duplicate windows.
  local -A open
  local p
  while IFS= read -r p; do
    [[ -n "$p" ]] && open[$p]=1
  done < <(tmux list-panes -a -F '#{pane_current_path}')

  local path win count=0
  while IFS= read -r path; do
    [[ -z "$path" || ! -d "$path" ]] && continue
    [[ -n "${open[$path]}" ]] && continue
    win=$(tmux new-window -d -c "$path" -P -F '#{window_id}')
    if [[ "$path" == *.worktrees/* ]]; then
      tmux send-keys -t "$win" "yolo --resume" Enter
    fi
    open[$path]=1
    (( count++ ))
  done < "$file"
  echo "wtr: opened $count window(s)"
}
