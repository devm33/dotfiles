# Create a codespace for the current repo on the given branch (defaults to
# main) and print its name to stdout. Progress goes to stderr so the name can
# be captured with `name=$(cs [branch])`. When run interactively it also ssh's
# into the new codespace.
cs() {
  local branch="${1:-main}"
  local repo
  repo=$(gh repo view --json nameWithOwner -q .nameWithOwner) || return 1

  echo "Creating codespace for $repo on branch $branch..." >&2
  # Pick a machine type so create doesn't try to prompt (it can't, since its
  # output is captured -> "no terminal"). Honor $CS_MACHINE if set, otherwise
  # default to the largest available (most cpus, then most storage).
  local machine="${CS_MACHINE:-}"
  if [[ -z "$machine" ]]; then
    machine=$(gh api "/repos/$repo/codespaces/machines" \
      --jq '.machines | sort_by(.cpus, .storage_in_bytes) | last | .name' 2>/dev/null)
  fi
  local -a machine_flag
  [[ -n "$machine" ]] && machine_flag=(-m "$machine")
  local name
  name=$(gh codespace create -R "$repo" -b "$branch" --default-permissions "${machine_flag[@]}") || return 1
  echo "$name"

  # The first `gh codespace ssh` against a freshly created codespace has to
  # spin up the SSH server component in the container, which transiently fails
  # with "failed to start SSH server" until the container finishes booting.
  # Poll a trivial command until it succeeds so later ssh calls don't race it.
  echo "Waiting for SSH server to come up..." >&2
  local i
  for i in $(seq 1 60); do
    gh codespace ssh -c "$name" -- true 2>/dev/null && break
    sleep 2
  done

  # Codespaces apply dotfiles (which install tmux, zsh, etc.) asynchronously
  # after the container is ready, so connecting immediately races that setup.
  # Wait for install.sh to log completion before returning / connecting.
  echo "Waiting for dotfiles install to finish..." >&2
  gh codespace ssh -c "$name" -- 'for i in $(seq 1 150); do grep -q "Dotfiles install complete" /workspaces/.codespaces/.persistedshare/creation.log 2>/dev/null && exit 0; sleep 2; done' 2>/dev/null

  # When run interactively (stdout is a terminal) connect to the codespace. When
  # the output is captured (e.g. by ccr) just return the name.
  if [[ -t 1 ]]; then
    echo "Connecting to $name..." >&2
    gh codespace ssh -c "$name"
  fi
}
# SSH into a codespace (prompts to pick one when no -c <name> is given).
alias cssh='gh codespace ssh'

# Durably SSH into a codespace. Improves on plain `cssh` for flaky networks:
#   * Tight keepalives (~45s) so a dead connection is detected fast instead of
#     hanging on the socket for minutes.
#   * Attaches via `ta` (plain attach, or a fresh session if the server was
#     killed, e.g. the codespace restarted). Run `wtr` afterward to rebuild your
#     saved worktree windows.
#   * Auto-reconnects on an unexpected drop; a clean tmux detach (prefix-d)
#     exits 0 and stops the loop.
#   * Resets local terminal state after each disconnect so an abrupt drop
#     doesn't leave the shell in raw mode / alt-screen.
# Usage: `csd` (prompts once) or `csd -c <name>`. Extra args pass through to gh.
csd() {
  # Resolve the codespace name once up front so reconnects don't re-prompt.
  # If the caller already passed -c/--codespace, honor it and skip selection.
  local -a args=("$@")
  local has_name=
  local a
  for a in "$@"; do
    [[ "$a" == "-c" || "$a" == "--codespace" ]] && { has_name=1; break; }
  done
  if [[ -z "$has_name" ]]; then
    local name
    # Pull richer metadata for the picker. The codespace name is kept as a
    # hidden first column (tab-separated) so we can recover it after selection.
    local rows
    rows=$(gh codespace list \
      --json name,repository,gitStatus,state,displayName,lastUsedAt \
      --jq 'sort_by(.lastUsedAt) | reverse | .[] | [.name, .repository, (.gitStatus.ref // "?"), .state, .displayName] | @tsv') || return 1
    if [[ -z "$rows" ]]; then
      echo "No codespaces found." >&2
      return 1
    fi
    # Align columns (repo / branch / state / display name) for readability.
    local table
    table=$(printf '%s\n' "$rows" | awk -F'\t' '
      { name[NR]=$1; repo[NR]=$2; ref[NR]=$3; state[NR]=$4; disp[NR]=$5
        if (length($2)>wr) wr=length($2)
        if (length($3)>wf) wf=length($3)
        if (length($4)>ws) ws=length($4) }
      END { for (i=1;i<=NR;i++)
              printf "%s\t%-*s  %-*s  %-*s  %s\n", name[i], wr, repo[i], wf, ref[i], ws, state[i], disp[i] }')
    if [[ $(printf '%s\n' "$table" | grep -c .) -eq 1 ]]; then
      name=${table%%$'\t'*}
    elif command -v fzf >/dev/null 2>&1; then
      local sel
      sel=$(printf '%s\n' "$table" | fzf --height=40% --reverse --with-nth=2.. --delimiter='\t') || return 1
      name=${sel%%$'\t'*}
    else
      local PS3="Select a codespace: " line
      select line in "${(@f)$(printf '%s\n' "$table" | cut -f2-)}"; do
        [[ -n "$line" ]] && break
      done
      [[ -z "$line" ]] && return 1
      name=$(printf '%s\n' "$table" | awk -F'\t' -v d="$line" '$2==d{print $1; exit}')
    fi
    [[ -z "$name" ]] && return 1
    args=(-c "$name" "${args[@]}")
  fi
  while true; do
    gh codespace ssh "${args[@]}" -- \
      -o ServerAliveInterval=15 -o ServerAliveCountMax=3 \
      -t 'zsh -c ta'
    local rc=$?
    # Restore local terminal after tmux/ssh may have left it in a bad state.
    stty sane 2>/dev/null
    printf '\033[?1049l\033[?25h'  # leave alt-screen, show cursor
    # Clean detach/exit -> stop. Any other exit is treated as a drop.
    [[ $rc -eq 0 ]] && break
    printf '[%s] Codespace connection dropped (rc=%s). Reconnecting... (Ctrl-C to stop)\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$rc" >&2
    sleep 1
  done
}

# Delete branch and its associated worktree (if any)
gbDW() {
  for b in "$@"; do
    wt=$(git worktree list --porcelain | awk -v branch="refs/heads/$b" '/^worktree /{wt=$0} $0 == "branch " branch {sub(/^worktree /, "", wt); print wt}')
    if [ -n "$wt" ]; then
      echo "Removing worktree: $wt (branch: $b)"
      git worktree remove --force "$wt"
    fi
    git branch -D "$b"
  done
}
# Remove worktrees for gone branches, then delete the branches
gwgD() {
  for b in $(LANG=C git branch --no-color -vv | grep ": gone\]" | sed 's/^[+* ]*//' | awk '{print $1}'); do
    wt=$(git worktree list --porcelain | awk -v branch="refs/heads/$b" '/^worktree /{wt=$0} $0 == "branch " branch {sub(/^worktree /, "", wt); print wt}')
    if [ -n "$wt" ]; then
      echo "Removing worktree: $wt (branch: $b)"
      # Close any tmux window with panes in this worktree
      if [ -n "$TMUX" ]; then
        local win_id
        win_id=$(tmux list-panes -s -F '#{window_id} #{pane_current_path}' | awk -v wt="$wt" '$2 == wt || index($2, wt"/") == 1 {print $1; exit}')
        if [ -n "$win_id" ]; then
          echo "Closing tmux window: $win_id"
          tmux kill-window -t "$win_id"
        fi
      fi
      git worktree remove --force "$wt"
      rm -rf "$wt"
    fi
    git branch -D "$b"
  done
}
alias wgwD='gwgD'
# Delete a single worktree by name and force delete its branch
wtD() {
  if [[ -z "$1" ]]; then
    echo "Usage: wtD <branch-name>"
    return 1
  fi

  local repo_root
  repo_root=$(git rev-parse --show-toplevel) || return 1

  # Determine branch name using the same logic as wt
  local wt_branch
  if [[ "$1" == devm33/* ]] || git show-ref --verify --quiet "refs/heads/$1" || git show-ref --verify --quiet "refs/remotes/origin/$1"; then
    wt_branch="$1"
  else
    wt_branch="devm33/$1"
  fi

  # Remove the worktree if it exists
  local wt
  wt=$(git worktree list --porcelain | awk -v branch="refs/heads/$wt_branch" '/^worktree /{wt=$0} $0 == "branch " branch {sub(/^worktree /, "", wt); print wt}')
  if [ -n "$wt" ]; then
    echo "Removing worktree: $wt (branch: $wt_branch)"
    git worktree remove --force "$wt"
  fi

  git branch -D "$wt_branch"
}
