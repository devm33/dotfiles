_pr_info() {
  local json="$1"
  local local_repo="$2"
  setopt local_options no_monitor no_notify
  local url title review mergeable base head_oid state is_draft auto_merge
  url=$(jq -r '.url' <<< "$json")
  title=$(jq -r '.title' <<< "$json")
  review=$(jq -r '.reviewDecision' <<< "$json")
  mergeable=$(jq -r '.mergeable' <<< "$json")
  state=$(jq -r '.state' <<< "$json")
  is_draft=$(jq -r '.isDraft' <<< "$json")
  auto_merge=$(jq -r 'if .autoMergeRequest == null then "false" else "true" end' <<< "$json")
  base=$(jq -r '.baseRefName' <<< "$json")
  head_oid=$(jq -r '.headRefOid' <<< "$json")

  # Required checks need a separate GraphQL query (statusCheckRollup has no
  # isRequired flag). Kick it off in the background so it runs concurrently while
  # we print everything else; the result is printed last once it completes.
  local req_file="" req_pid=""
  if [[ "$state" == "OPEN" && "$url" =~ 'github.com/([^/]+)/([^/]+)/pull/([0-9]+)' ]]; then
    local owner="${match[1]}" repo="${match[2]}" num="${match[3]}"
    req_file=$(mktemp)
    gh api graphql -F owner="$owner" -F repo="$repo" -F pr="$num" -f query='
      query($owner:String!,$repo:String!,$pr:Int!){
        repository(owner:$owner,name:$repo){
          pullRequest(number:$pr){
            commits(last:1){nodes{commit{statusCheckRollup{contexts(first:100){nodes{
              __typename
              ... on CheckRun { conclusion isRequired(pullRequestNumber:$pr) }
              ... on StatusContext { state isRequired(pullRequestNumber:$pr) }
            }}}}}}
          }
        }
      }' --jq '
      [.data.repository.pullRequest.commits.nodes[0].commit.statusCheckRollup.contexts.nodes[]
        | select(.isRequired == true) | (.conclusion // .state)] as $r
      | "\($r | length) \([$r[] | select(. == "SUCCESS")] | length) \([$r[] | select(. == "FAILURE" or . == "ERROR")] | length)"
    ' > "$req_file" 2>/dev/null &
    req_pid=$!
  fi

  # Author
  local author
  author=$(jq -r '.author.login' <<< "$json")

  # Labels
  local labels
  labels=$(jq -r '[.labels[].name] | join(", ")' <<< "$json")

  # Checks summary (all checks)
  local total passed failed pending
  total=$(jq '.statusCheckRollup | length' <<< "$json")
  passed=$(jq '[.statusCheckRollup[] | select(.conclusion == "SUCCESS")] | length' <<< "$json")
  failed=$(jq '[.statusCheckRollup[] | select(.conclusion == "FAILURE" or .conclusion == "ERROR")] | length' <<< "$json")
  pending=$(( total - passed - failed ))

  # Output
  echo "\033[1m$title\033[0m"
  echo "$url"
  if [[ -n "$author" && "$author" != "null" ]]; then
    echo "author:   \033[36m$author\033[0m"
  fi
  if [[ -n "$labels" ]]; then
    echo "labels:   \033[36m$labels\033[0m"
  fi

  if [[ "$state" == "MERGED" ]]; then
    echo "state:    \033[35m✓ merged\033[0m"
    return 0
  elif [[ "$state" == "CLOSED" ]]; then
    echo "state:    \033[31m✗ closed\033[0m"
    return 0
  fi

  if [[ "$is_draft" == "true" ]]; then
    echo "state:    \033[90m● draft\033[0m"
  else
    echo "state:    \033[32m✓ ready\033[0m"
  fi

  if (( failed > 0 )); then
    echo "checks:   \033[31m✗ $failed failing\033[0m ($passed/$total passed)"
  elif (( pending > 0 )); then
    echo "checks:   \033[33m● $pending pending\033[0m ($passed/$total passed)"
  elif (( total > 0 )); then
    echo "checks:   \033[32m✓ all $total passed\033[0m"
  else
    echo "checks:   no checks"
  fi

  # Reviewers who approved
  local approvers
  approvers=$(jq -r '[.latestReviews[]? | select(.state == "APPROVED") | .author.login] | join(", ")' <<< "$json")

  case "$review" in
    APPROVED)
      if [[ -n "$approvers" ]]; then
        echo "review:   \033[32m✓ approved by $approvers\033[0m"
      else
        echo "review:   \033[32m✓ approved\033[0m"
      fi ;;
    CHANGES_REQUESTED) echo "review:   \033[31m✗ changes requested\033[0m" ;;
    REVIEW_REQUIRED)   echo "review:   \033[33m● review required\033[0m" ;;
    *)                 echo "review:   \033[33m● pending\033[0m" ;;
  esac

  # GitHub returns UNKNOWN while computing merge status; retry a few times
  if [[ "$mergeable" == "UNKNOWN" ]]; then
    local i
    for i in 1 2 3; do
      sleep 1
      mergeable=$(gh pr view "$url" --json mergeable --jq '.mergeable' 2>/dev/null) || break
      [[ "$mergeable" != "UNKNOWN" ]] && break
    done
  fi
  case "$mergeable" in
    MERGEABLE)   echo "merge:    \033[32m✓ no conflicts\033[0m" ;;
    CONFLICTING) echo "merge:    \033[31m✗ has conflicts\033[0m" ;;
    *)           echo "merge:    \033[33m● unknown\033[0m" ;;
  esac

  if [[ "$auto_merge" == "true" ]]; then
    echo "automerge:\033[32m ✓ enabled\033[0m"
  else
    echo "automerge:\033[90m ✗ disabled\033[0m"
  fi

  # Commits ahead/behind base
  local behind="?" ahead="?"
  if [[ -n "$local_repo" ]]; then
    behind=$(git rev-list --count "$head_oid..origin/$base" 2>/dev/null || echo "?")
    ahead=$(git rev-list --count "origin/$base..$head_oid" 2>/dev/null || echo "?")
  else
    local repo_nwo compare
    repo_nwo=$(sed -E 's|https://github.com/([^/]+/[^/]+)/pull/.*|\1|' <<< "$url")
    compare=$(gh api "repos/$repo_nwo/compare/$base...$head_oid" 2>/dev/null)
    behind=$(jq -r '.behind_by' <<< "$compare" 2>/dev/null || echo "?")
    ahead=$(jq -r '.ahead_by' <<< "$compare" 2>/dev/null || echo "?")
    [[ -z "$behind" || "$behind" == "null" ]] && behind="?"
    [[ -z "$ahead" || "$ahead" == "null" ]] && ahead="?"
  fi

  if [[ "$behind" == "0" ]]; then
    echo "vs $base:  \033[32m↑$ahead ↓$behind\033[0m (up to date)"
  else
    echo "vs $base:  \033[33m↑$ahead ↓$behind\033[0m"
  fi

  # Required checks: wait for the background query launched earlier, then print
  if [[ -n "$req_pid" ]]; then
    wait "$req_pid" 2>/dev/null
    local req_counts req_total req_passed req_failed req_pending
    req_counts=$(<"$req_file"); rm -f "$req_file"
    if [[ -n "$req_counts" ]]; then
      read -r req_total req_passed req_failed <<< "$req_counts"
      req_pending=$(( req_total - req_passed - req_failed ))
      if (( req_total == 0 )); then
        echo "required: \033[90mnone\033[0m"
      elif (( req_failed > 0 )); then
        echo "required: \033[31m✗ $req_failed failing\033[0m ($req_passed/$req_total passed)"
      elif (( req_pending > 0 )); then
        echo "required: \033[33m● $req_pending pending\033[0m ($req_passed/$req_total passed)"
      else
        echo "required: \033[32m✓ all $req_total passed\033[0m"
      fi
    fi
  fi
}

pr() {
  local json
  json=$(gh pr view --json state,url,title,reviewDecision,mergeable,statusCheckRollup,baseRefName,headRefOid,labels,author,latestReviews,isDraft,autoMergeRequest) || return 1
  _pr_info "$json" local
}

prall() {
  local urls
  local since
  since=$(date -v-50d +%Y-%m-%d)
  urls=$(gh search prs --author @me --state open --created ">=$since" --json repository,number -q '.[] | .repository.nameWithOwner + " " + (.number | tostring)') || return 1
  if [[ -z "$urls" ]]; then
    echo "No open PRs found."
    return 0
  fi
  local first=1 json
  while IFS=' ' read -r repo num; do
    (( first )) || echo
    first=0
    json=$(gh pr view "$num" -R "$repo" --json state,url,title,reviewDecision,mergeable,statusCheckRollup,baseRefName,headRefOid,labels,author,latestReviews,isDraft,autoMergeRequest 2>/dev/null) || continue
    _pr_info "$json"
  done <<< "$urls"
}

alias datetime='date +%Y%m%dT%H%M%S'

alias proxy='HTTP_PROXY=http://localhost:9090'

command_not_found_handler() {
    if [[ $# -gt 1 ]]; then
        if ! type yolo >/dev/null 2>&1; then
            echo "zsh: command not found: $1" >&2
            return 127
        fi
        local prompt="$*"
        eval "yolo -i ${(q)prompt}"
        return $?
    fi
    echo "zsh: command not found: $1" >&2
    return 127
}
