# Create a worktree with a random word-pair name
wtp() {
  local adjectives=(
    bright cool fast green happy lucky quick red sharp warm
    blue calm dark fresh golden hidden iron keen noble swift
  )
  local nouns=(
    bear cobra dolphin dynamo eagle falcon hawk lion panther tiger
    cedar coral flame glacier mesa orbit pixel spark wolf zenith
  )
  local adj=${adjectives[$((RANDOM % ${#adjectives[@]} + 1))]}
  local noun=${nouns[$((RANDOM % ${#nouns[@]} + 1))]}
  local name="${adj}-${noun}"
  echo "Worktree name: $name"
  wt "$name" "$@"
}

