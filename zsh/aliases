# Functions to help manage dotfiles
dotup () {
    pushd ~/.dotfiles
    git pull
    if [ "$1" ]; then
        git commit -v -a
        git push
    fi
    rcup -v
    . ~/.zshrc
    popd
}

alias dotca='dotup 1'

dotall () {
    if [ ! -r ~/.rcrc ]; then
        if [ "$1" ]; then dotca; else dotup; fi
        return
    fi
    for d in `sed -n 's/DOTFILES_DIRS="\(.*\)"/\1/p' ~/.rcrc`; do
        eval df=$d
        pushd $df
        git pull
        if [ "$1" ]; then
            git commit -v -a
            git push
        fi
        popd
    done
    rcup -v
}

