_prps_number() {
  local number="$1"
  if [[ -z "$number" ]]; then
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD) || return 1
    number=$(gh pr list --head "$branch" --state open --json number --jq '.[0].number')
  fi
  if [[ -z "$number" ]]; then
    echo "no open PR found for current branch" >&2
    return 1
  fi
  echo "$number"
}
