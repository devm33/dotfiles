dotall () {
    if [ ! -r ~/.rcrc ]; then
        if [ "$1" ]; then dotca; else dotup; fi
        return
    fi
    for d in `sed -n 's/DOTFILES_DIRS="\(.*\)"/\1/p' ~/.rcrc`; do
        eval df=$d
        pushd $df
        git pull
        if [ "$1" ]; then
            git commit -v -a
            git push
        fi
        popd
    done
    rcup -v
}

